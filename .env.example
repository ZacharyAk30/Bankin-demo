APP_ENV=local
LOG_LEVEL=INFO

# Local “S3” root (filesystem)
S3_LOCAL_ROOT=data/lake

# DuckDB “warehouse”
DUCKDB_PATH=data/warehouse/bankin.duckdb

# MLflow tracking
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT_NAME=bankin_tx_categorization

# Model serving
MODEL_LATEST_PATH=models/artifacts/latest/model.joblib

# Hybrid system
ML_CONFIDENCE_THRESHOLD=0.65
LLM_ENABLED=true
LLM_CACHE_DIR=data/cache/llm
LLM_MAX_QPS=5
LLM_SIMULATED_LATENCY_MS=450
LLM_COST_PER_1K_TOKENS_USD=0.003
